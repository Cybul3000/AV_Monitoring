{
  "name": "av-monitoring",
  "version": "0.1.0",
  "description": "Cross-platform AV room monitoring and self-healing desktop application",
  "main": "dist-electron/main/index.js",
  "private": true,
  "scripts": {
    "dev": "npm run rebuild:native && electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:all": "npm run build && electron-builder --mac --win",
    "preview": "electron-vite preview",
    "test": "npm run rebuild:node && vitest run",
    "test:watch": "npm run rebuild:node && vitest",
    "test:coverage": "npm run rebuild:node && vitest run --coverage",
    "e2e": "npm run rebuild:native && npx playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "rebuild:native": "electron-rebuild",
    "rebuild:node": "npm rebuild better-sqlite3",
    "db:schema": "node scripts/db-schema.mjs",
    "otel:generate-example": "node scripts/otel-generate-example.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "better-sqlite3": "^12.8.0",
    "electron-store": "^8.2.0",
    "keytar": "^7.9.0",
    "multicast-dns": "^7.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@playwright/test": "^1.44.0",
    "@types/better-sqlite3": "^7.6.10",
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.5",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.5.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vitest": "^1.5.2"
  },
  "build": {
    "appId": "com.av-monitoring.app",
    "productName": "AV Monitoring",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "dist/**",
      "resources/**",
      "!resources/**/*.pdf"
    ],
    "extraResources": [
      {
        "from": "resources/device-registry.json",
        "to": "device-registry.json"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
